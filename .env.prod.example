MYSQL_DATABASE=campushub
MYSQL_USER=campushub
MYSQL_PASSWORD=change-me-use-strong-random-password
MYSQL_ROOT_PASSWORD=change-me-use-strong-random-root-password

CAMPUSHUB_WEB_PORT=18080
CAMPUSHUB_JWT_SECRET=change-me-at-least-32-bytes-random-secret
CAMPUSHUB_JWT_ISSUER=campushub

CAMPUSHUB_PAYMENT_PROVIDER=payment-center
CAMPUSHUB_PAYMENT_MOCK_ENABLED=false
CAMPUSHUB_PAYMENT_CENTER_BASE_URL=http://api-transfer-station-internal:8080
CAMPUSHUB_PAYMENT_CENTER_CREATE_PATH=/internal/payments/campushub/orders
CAMPUSHUB_PAYMENT_CENTER_CALLBACK_URL=https://ustc.suntomb.qzz.io/api/payment/callbacks/payment-center
CAMPUSHUB_PAYMENT_CENTER_CALLBACK_TOKEN=replace-with-internal-token
CAMPUSHUB_PAYMENT_CENTER_SIGNING_SECRET=replace-with-internal-signing-secret
CAMPUSHUB_PAYMENT_ORDER_EXPIRE_MINUTES=30

CAMPUSHUB_MAIL_ENABLED=true
CAMPUSHUB_MAIL_PROVIDER=brevo
CAMPUSHUB_MAIL_SMTP_HOST=smtp-relay.brevo.com
CAMPUSHUB_MAIL_SMTP_PORT=587
CAMPUSHUB_MAIL_SMTP_USERNAME=change-me
CAMPUSHUB_MAIL_SMTP_PASSWORD=change-me
CAMPUSHUB_MAIL_FROM=suntomb@suntomb.qzz.io
CAMPUSHUB_MAIL_FROM_NAME=校集 CampusHub
CAMPUSHUB_MAIL_CODE_TTL_MINUTES=10
CAMPUSHUB_MAIL_CODE_RESEND_SECONDS=60

CAMPUSHUB_WECHAT_MANUAL_QR_URL=https://example.com/campushub-wechat-qr.png
CAMPUSHUB_WECHAT_MANUAL_NOTE=扫码支付后请备注充值订单号，管理员审核后入账。

# Beta demo reset is disabled by default. Set passwords only on the server, never in git.
CAMPUSHUB_BETA_DEMO_RESET_ENABLED=false
CAMPUSHUB_BETA_STUDENT_EMAIL=demo-student@example.edu.cn
CAMPUSHUB_BETA_STUDENT_USERNAME=demo-student
CAMPUSHUB_BETA_STUDENT_PASSWORD=change-me-use-strong-demo-password
CAMPUSHUB_BETA_STUDENT_NO=BETA-STUDENT-001
CAMPUSHUB_BETA_STUDENT_REAL_NAME=Beta Student
CAMPUSHUB_BETA_STUDENT_NICKNAME=Beta Student
CAMPUSHUB_BETA_STUDENT_PHONE=13900000001
CAMPUSHUB_BETA_STUDENT_WECHAT=demo-student-wechat
CAMPUSHUB_BETA_STUDENT_QQ=
